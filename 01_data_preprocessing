library(Seurat)
library(tidyverse)
set.seed(333)

project_dir <- "."   # or change to "path/to/ConM_project"
setwd(project_dir)

seurat_conM <- readRDS("Analysis/01_Demultiplexing/ConM_10x_data_demux_with_Samples.RDS")

View(seurat_conM)

# % MT reads
seurat_conM[["percent.mt"]] <- PercentageFeatureSet(seurat_conM, pattern = "^MT-")
seurat_conM[["percent.ribo"]] <- PercentageFeatureSet(seurat_conM, pattern = "RP[SL]")
View(seurat_conM@meta.data)

#plot qc metrices and summary before filtering
#qc_plot <- VlnPlot(seurat_conM, features = c("nFeature_RNA","nCount_RNA","percent.mt"), ncol = 3) ; qc_plot
#One group vilion plot
seurat_conM$group_all <- "All"
qc_plot <- VlnPlot(seurat_conM, features = c("nFeature_RNA","nCount_RNA","percent.mt"),group.by = "group_all", ncol = 3) ; qc_plot
feature_plot <- FeatureScatter(seurat_conM, feature1 = "nCount_RNA", feature2 = "percent.mt") + geom_smooth(method = "lm") 
#shows whether higher counts correlate with more mitochondrial reads
mt_plot <- FeatureScatter(seurat_conM, feature1 = "nCount_RNA", feature2 = "nFeature_RNA") + geom_smooth(method = "lm")
#Outliers (very high counts but low features) may indicate doublets or low-complexity cells
feature_plot | mt_plot

#filtering the data
seurat_conM <- subset(seurat_conM, subset = nFeature_RNA > 300 & nFeature_RNA < 3000 & percent.mt < 6)
#check those values from previous figures
View(seurat_conM@meta.data)

#plot qc metrics and summary after filtering
qc_plot_filtered <- VlnPlot(seurat_conM, features = c("nFeature_RNA","nCount_RNA","percent.mt"),group.by = "group_all", ncol = 3) ; qc_plot_filtered
feature_plot_filtered <- FeatureScatter(seurat_conM, feature1 = "nCount_RNA", feature2 = "percent.mt") + geom_smooth(method = "lm")
mt_plot_filtered <- FeatureScatter(seurat_conM, feature1 = "nCount_RNA", feature2 = "nFeature_RNA") + geom_smooth(method = "lm")
feature_plot_filtered | mt_plot_filtered

## Summary Plot Before After
features_df <- data.frame(
  Features = c(17559, 12766, 17559, 12622),
  Assay = rep(c("RNA_features", "Cell_numbers"), 2),
  Status = rep(c("Before", "After"), each = 2)
)
cell_counts <- seurat_conM@meta.data %>%
  as.data.frame() %>%
  dplyr::count(Sample_ID, name = "Cell_Count")
## Bar plots
features_plot <- ggplot(features_df, aes(x = Assay, y= Features, fill = Status)) +
  geom_bar(stat = "identity", position = "dodge") +
  theme_minimal()+
  scale_fill_manual(values = c("Before" = "steelblue", "After" = "tomato")); features_plot

cell_counts_plot_a <- ggplot(
  cell_counts,
  aes(x = Sample_ID, y = Cell_Count, fill =  Sample_ID)) +
    geom_bar(stat = "identity") +
    theme_minimal() +
    labs(title = "Final Cell Count per Sample", x = "Sample", y = "Number of Cells") +
    theme(axis.text.x = element_text(angle = 45, hjust = 1)); cell_counts_plot_a


#save seurat object
saveRDS(seurat_conM, file = "Seurat_conM_cleanUp.RDS")

#save qc plots
pdf(file = "ConM_10x_scRNAseq_QC_plots.pdf", paper= "a4r")
print(qc_plot)
print(feature_plot)
print(mt_plot)
print(qc_plot_filtered)
print(feature_plot_filtered)
print(mt_plot_filtered)
print(features_plot)
print(cell_counts_plot_a)
dev.off()
