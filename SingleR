  ggtitle("Novershtern Hematopoietic Data - Main") ; MainAnnot_nov_umap_plot
# save the file and RDS
saveRDS(seurat_conM, file = "SingleR_annot.RDS")
pdf(file = "ConM_scRNAseq_SingleR_Labels_UMAP.pdf", width = 16, height = 8)


print(FineAnnot_monaco_umap_plot)
