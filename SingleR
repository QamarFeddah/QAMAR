# UMAP Plot
FineAnnot_nov_umap_plot <- DimPlot(seurat_conM, repel = TRUE, group.by = "FineAnnotation")+
  ggtitle("Novershtern Hematopoietic Data - Fine") ; FineAnnot_nov_umap_plot
